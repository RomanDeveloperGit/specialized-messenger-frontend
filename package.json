{
  "name": "specialized-messenger-frontend",
  "description": "An application for professionals that allows them to communicate with their consumers",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ts:check": "tsc --noEmit",
    "lint:check": "eslint",
    "stylelint:check": "stylelint .",
    "format": "prettier . --write && concurrently \"eslint --fix\" \"stylelint . --fix\"",
    "start:dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env tsc -b && cross-env NODE_ENV=production vite build"
  },
  "dependencies": {
    "@specialized-messenger/api": "^1.13.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "postcss-load-config": "^6.0.1",
    "postcss-preset-env": "^11.2.1",
    "postcss-sort-media-queries": "^6.5.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-sass-dts": "^1.3.37"
  },
  "browserslist": [
    "last 4 version",
    "> 0.5%",
    "not dead"
  ],
  "engines": {
    "node": ">=25.9.0",
    "yarn": ">=4.13.0"
  },
  "packageManager": "yarn@4.13.0"
}
